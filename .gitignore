# ---- Zig ----
.zig-cache/
zig-cache/
zig-out/

# ---- V8 (huge — fetched on demand by scripts/fetch_v8.sh) ----
# Source checkout: ~5.5 GB. Build artifacts: ~6 GB. Never commit.
vendor/v8/
vendor/depot_tools/

# ---- QuickJS-NG (fetched on demand by scripts/fetch_quickjs.sh) ----
# Has its own .git from `git clone`. Excluded to avoid an embedded repo.
vendor/quickjs/

# Note: vendor/lua/ IS committed — it's the upstream PUC Lua 5.4.8 source
# tree (no .git). Hermetic build.

# ---- Generated host artifacts ----
# v8_host.o is staged by `zig build` from src/hosts/v8_host.zig.
# v8_shim.o is built by scripts/build_v8_shim.sh.
src/hosts/v8_host.o
src/hosts/v8_shim.o

# ---- TS pipeline outputs ----
# Generated by tools/ts/ npm run build. Recreate with one command.
src/workloads/ts-out-lua/
src/workloads/ts-out-js/

# ---- Node ----
tools/ts/node_modules/

# ---- Logs ----
*.log
/tmp/v8_*.log

# ---- Editor / OS ----
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp
*.swo
*~
